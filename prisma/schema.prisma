generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Locale {
  vi
  de
}

enum Role {
  GUEST
  USER
  STAFF
  EDITOR
  ADMIN
  SUPER_ADMIN
}

enum AccountType {
  PERSONAL
  BUSINESS
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SCHEDULED
}

enum QuoteStatus {
  DRAFT
  SUBMITTED
  REVIEWING
  NEED_MORE_INFO
  QUOTED
  ACCEPTED
  REJECTED
  CONVERTED_TO_PROJECT
  ARCHIVED
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  REVIEW
  REVISION
  PRODUCTION
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  AWAITING_APPROVAL
  APPROVED
  REJECTED
  DONE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  RESCHEDULED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum NotificationType {
  SYSTEM
  QUOTE
  PROJECT
  APPOINTMENT
  MESSAGE
  BILLING
  AI
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  QUOTED
  WON
  LOST
  ARCHIVED
}

enum LeadSource {
  CONTACT
  QUOTE
  AI_ASSISTANT
  PROJECT_LAB
  REFERRAL
  ORGANIC
  ADS
  OTHER
}

enum MediaVisibility {
  PUBLIC
  PRIVATE
}

enum MediaKind {
  IMAGE
  DOCUMENT
  CAD
  ARCHIVE
  OTHER
}

// ─── Auth & Users ────────────────────────────────────────

model User {
  id                String       @id @default(cuid())
  email             String       @unique
  emailVerified     DateTime?
  passwordHash      String?
  name              String
  phone             String?
  accountType       AccountType  @default(PERSONAL)
  preferredLocale   Locale       @default(vi)
  role              Role         @default(USER)
  image             String?
  isActive          Boolean      @default(true)
  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?
  aiConsentAt       DateTime?
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  company           Company?
  addresses         Address[]
  accounts          Account[]
  sessions          Session[]
  userRoles         UserRole[]
  emailTokens       EmailVerificationToken[]
  passwordResets    PasswordResetToken[]
  rateLimits        RateLimitHit[]
  contactSubmissions ContactSubmission[]
  leadsOwned        Lead[]              @relation("LeadOwner")
  leadsAssigned     Lead[]              @relation("LeadAssignee")
  quoteRequests     QuoteRequest[]      @relation("QuoteOwner")
  quotesAssigned    QuoteRequest[]      @relation("QuoteAssignee")
  quotesAuthored    Quote[]
  projectsOwned     Project[]           @relation("ProjectOwner")
  projectsStaff     Project[]           @relation("ProjectStaff")
  projectComments   ProjectComment[]
  appointments      Appointment[]       @relation("AppointmentUser")
  appointmentsHost  Appointment[]       @relation("AppointmentHost")
  notifications     Notification[]
  aiConversations   AIConversation[]
  mediaAssets       MediaAsset[]
  consentLogs       ConsentLog[]
  auditLogs         AuditLog[]
  testimonials      Testimonial[]

  @@index([role, isActive])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RateLimitHit {
  id        String   @id @default(cuid())
  userId    String?
  key       String
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([key, createdAt])
  @@index([ip, createdAt])
}

// Flexible RBAC (Role enum on User is primary; UserRole/Permission for fine-grained admin UI)
model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  rolePerms   RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      Role
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model Company {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  vatId     String?
  website   String?
  industry  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id         String  @id @default(cuid())
  userId     String?
  user       User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String?
  line1      String
  line2      String?
  city       String
  postalCode String
  country    String  @default("DE")
  isPrimary  Boolean @default(false)
}

// ─── CMS: Services ───────────────────────────────────────

model ServiceCategory {
  id          String                   @id @default(cuid())
  code        String                   @unique // CNC, WERBETECHNIK, ...
  sortOrder   Int                      @default(0)
  icon        String?
  visual      String?
  status      ContentStatus            @default(PUBLISHED)
  formSchema  Json?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  translations ServiceCategoryTranslation[]
  services    Service[]
}

model ServiceCategoryTranslation {
  id          String          @id @default(cuid())
  categoryId  String
  category    ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale      Locale
  name        String
  description String?         @db.Text

  @@unique([categoryId, locale])
}

model Service {
  id           String               @id @default(cuid())
  categoryId   String
  category     ServiceCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  slug         String               @unique // fallback canonical
  icon         String?
  visual       String?
  specs        String[]
  sortOrder    Int                  @default(0)
  status       ContentStatus        @default(DRAFT)
  publishedAt  DateTime?
  scheduledAt  DateTime?
  formSchema   Json?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  translations ServiceTranslation[]
  seo          SEOData?
  quoteRequests QuoteRequest[]
  portfolio    PortfolioService[]
  contentRevisions ContentRevision[] @relation("ServiceRevisions")

  @@index([status, sortOrder])
}

model ServiceTranslation {
  id            String   @id @default(cuid())
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  locale        Locale
  slug          String
  title         String
  short         String   @db.Text
  description   String   @db.Text
  capabilities  String[]
  benefits      String[]

  @@unique([serviceId, locale])
  @@unique([locale, slug])
}

// ─── CMS: Industries ─────────────────────────────────────

model Industry {
  id           String                 @id @default(cuid())
  slug         String                 @unique
  icon         String?
  palette      String?
  modules      String[]
  sortOrder    Int                    @default(0)
  status       ContentStatus          @default(DRAFT)
  publishedAt  DateTime?
  scheduledAt  DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  translations IndustryTranslation[]
  seo          SEOData?
  portfolio    PortfolioProject[]
}

model IndustryTranslation {
  id            String   @id @default(cuid())
  industryId    String
  industry      Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)
  locale        Locale
  slug          String
  title         String
  short         String   @db.Text
  description   String   @db.Text
  painPoints    String[]
  deliverables  String[]
  packageText   String   @db.Text

  @@unique([industryId, locale])
  @@unique([locale, slug])
}

// ─── CMS: Portfolio ──────────────────────────────────────

model PortfolioProject {
  id           String                  @id @default(cuid())
  slug         String                  @unique
  category     String
  industryId   String?
  industry     Industry?               @relation(fields: [industryId], references: [id], onDelete: SetNull)
  status       ContentStatus           @default(DRAFT)
  featured     Boolean                 @default(false)
  sortOrder    Int                     @default(0)
  gradient     String?
  coverUrl     String?
  tags         String[]
  publishedAt  DateTime?
  scheduledAt  DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  translations PortfolioTranslation[]
  media        PortfolioMedia[]
  services     PortfolioService[]
  seo          SEOData?
}

model PortfolioTranslation {
  id            String           @id @default(cuid())
  projectId     String
  project       PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  locale        Locale
  slug          String
  title         String
  description   String           @db.Text
  materials     String?
  duration      String?
  result        String?          @db.Text
  beforeLabel   String?
  afterLabel    String?

  @@unique([projectId, locale])
  @@unique([locale, slug])
}

model PortfolioMedia {
  id        String           @id @default(cuid())
  projectId String
  project   PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  altVi     String?
  altDe     String?
  sortOrder Int              @default(0)
  kind      MediaKind        @default(IMAGE)
}

model PortfolioService {
  projectId String
  serviceId String
  project   PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  service   Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([projectId, serviceId])
}

// ─── CMS: Pricing / Blog / FAQ / Team / Testimonials ─────

model PricingPlan {
  id           String                  @id @default(cuid())
  categoryCode String
  slug         String
  sortOrder    Int                     @default(0)
  highlighted  Boolean                 @default(false)
  priceFrom    String
  currency     String                  @default("EUR")
  status       ContentStatus           @default(PUBLISHED)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  translations PricingPlanTranslation[]

  @@unique([categoryCode, slug])
}

model PricingPlanTranslation {
  id          String      @id @default(cuid())
  planId      String
  plan        PricingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  locale      Locale
  name        String
  unit        String
  description String      @db.Text
  features    String[]

  @@unique([planId, locale])
}

model BlogPost {
  id           String             @id @default(cuid())
  slug         String             @unique
  status       ContentStatus      @default(DRAFT)
  featured     Boolean            @default(false)
  readTime     Int                @default(5)
  gradient     String?
  coverUrl     String?
  publishedAt  DateTime?
  scheduledAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  translations BlogTranslation[]
  seo          SEOData?
  revisions    ContentRevision[]  @relation("BlogRevisions")
}

model BlogTranslation {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  locale    Locale
  slug      String
  title     String
  excerpt   String   @db.Text
  content   String   @db.Text
  category  String

  @@unique([postId, locale])
  @@unique([locale, slug])
}

model FAQ {
  id           String           @id @default(cuid())
  category     String
  sortOrder    Int              @default(0)
  status       ContentStatus    @default(PUBLISHED)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  translations FAQTranslation[]
}

model FAQTranslation {
  id       String @id @default(cuid())
  faqId    String
  faq      FAQ    @relation(fields: [faqId], references: [id], onDelete: Cascade)
  locale   Locale
  question String
  answer   String @db.Text

  @@unique([faqId, locale])
}

model TeamMember {
  id           String                   @id @default(cuid())
  name         String
  initials     String
  imageUrl     String?
  sortOrder    Int                      @default(0)
  status       ContentStatus            @default(PUBLISHED)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  translations TeamMemberTranslation[]
}

model TeamMemberTranslation {
  id     String     @id @default(cuid())
  teamId String
  team   TeamMember @relation(fields: [teamId], references: [id], onDelete: Cascade)
  locale Locale
  role   String
  bio    String     @db.Text

  @@unique([teamId, locale])
}

model Testimonial {
  id           String                    @id @default(cuid())
  authorName   String
  company      String?
  rating       Int                       @default(5)
  sortOrder    Int                       @default(0)
  status       ContentStatus             @default(PUBLISHED)
  userId       String?
  user         User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt    DateTime                  @default(now())
  translations TestimonialTranslation[]
}

model TestimonialTranslation {
  id            String      @id @default(cuid())
  testimonialId String
  testimonial   Testimonial @relation(fields: [testimonialId], references: [id], onDelete: Cascade)
  locale        Locale
  quote         String      @db.Text
  role          String?

  @@unique([testimonialId, locale])
}

model Page {
  id           String            @id @default(cuid())
  key          String            @unique // home, about, ...
  status       ContentStatus     @default(DRAFT)
  publishedAt  DateTime?
  scheduledAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  translations PageTranslation[]
  seo          SEOData?
}

model PageTranslation {
  id      String @id @default(cuid())
  pageId  String
  page    Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  locale  Locale
  slug    String
  title   String
  body    String @db.Text

  @@unique([pageId, locale])
  @@unique([locale, slug])
}

model NavigationItem {
  id        String              @id @default(cuid())
  parentId  String?
  parent    NavigationItem?     @relation("NavTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  NavigationItem[]    @relation("NavTree")
  href      String
  sortOrder Int                 @default(0)
  location  String              @default("header") // header | footer
  status    ContentStatus       @default(PUBLISHED)
  labels    NavigationLabel[]
}

model NavigationLabel {
  id     String         @id @default(cuid())
  itemId String
  item   NavigationItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  locale Locale
  label  String

  @@unique([itemId, locale])
}

model SEOData {
  id              String  @id @default(cuid())
  serviceId       String? @unique
  service         Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  industryId      String? @unique
  industry        Industry? @relation(fields: [industryId], references: [id], onDelete: Cascade)
  portfolioId     String? @unique
  portfolio       PortfolioProject? @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  blogPostId      String? @unique
  blogPost        BlogPost? @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  pageId          String? @unique
  page            Page? @relation(fields: [pageId], references: [id], onDelete: Cascade)
  metaTitleVi     String?
  metaTitleDe     String?
  metaDescVi      String? @db.Text
  metaDescDe      String? @db.Text
  ogImage         String?
  canonical       String?
  noIndex         Boolean @default(false)
}

model ContentRevision {
  id         String    @id @default(cuid())
  serviceId  String?
  service    Service?  @relation("ServiceRevisions", fields: [serviceId], references: [id], onDelete: Cascade)
  blogPostId String?
  blogPost   BlogPost? @relation("BlogRevisions", fields: [blogPostId], references: [id], onDelete: Cascade)
  authorId   String?
  snapshot   Json
  note       String?
  createdAt  DateTime  @default(now())
}

// ─── Leads / Contact / Quotes / Projects ─────────────────

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  service   String?
  message   String   @db.Text
  locale    Locale   @default(vi)
  handled   Boolean  @default(false)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead      Lead?
  createdAt DateTime @default(now())
}

model Lead {
  id          String     @id @default(cuid())
  reference   String     @unique
  status      LeadStatus @default(NEW)
  source      LeadSource @default(OTHER)
  score       Int        @default(0)
  name        String
  email       String
  phone       String?
  company     String?
  industry    String?
  notes       String?    @db.Text
  locale      Locale     @default(vi)
  ownerId     String?
  owner       User?      @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  assigneeId  String?
  assignee    User?      @relation("LeadAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  contactId   String?    @unique
  contact     ContactSubmission? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  quoteRequestId String? @unique
  quoteRequest QuoteRequest? @relation(fields: [quoteRequestId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, createdAt])
}

model QuoteRequest {
  id              String             @id @default(cuid())
  reference       String             @unique
  userId          String
  user            User               @relation("QuoteOwner", fields: [userId], references: [id], onDelete: Cascade)
  assigneeId      String?
  assignee        User?              @relation("QuoteAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  serviceId       String?
  service         Service?           @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  categoryCode    String?
  title           String
  status          QuoteStatus        @default(DRAFT)
  locale          Locale             @default(vi)
  description     String?            @db.Text
  /// CNC/Print/Signage/Website/Marketing structured fields
  specs           Json?
  budgetRange     String?
  timeline        String?
  deadline        DateTime?
  location        String?
  deliveryMode    String? // delivery | installation | pickup
  designFileNote  String?
  companyName     String?
  contactPhone    String?
  needsInfoNote   String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  submittedAt     DateTime?
  quotes          Quote[]
  files           QuoteRequestFile[]
  project         Project?
  lead            Lead?
  activities      AuditLog[]

  @@index([userId, status])
  @@index([status, createdAt])
}

model QuoteRequestFile {
  id             String       @id @default(cuid())
  quoteRequestId String
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  mediaId        String
  media          MediaAsset   @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model Quote {
  id             String       @id @default(cuid())
  quoteRequestId String
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  authorId       String
  author         User         @relation(fields: [authorId], references: [id])
  version        Int          @default(1)
  amountCents    Int
  currency       String       @default("EUR")
  validUntil     DateTime?
  notesVi        String?      @db.Text
  notesDe        String?      @db.Text
  pdfUrl         String?
  acceptedAt     DateTime?
  rejectedAt     DateTime?
  rejectReason   String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  items          QuoteItem[]

  @@index([quoteRequestId])
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  title       String
  description String? @db.Text
  quantity    Int     @default(1)
  unitCents   Int
  sortOrder   Int     @default(0)
}

model Project {
  id             String             @id @default(cuid())
  reference      String             @unique
  title          String
  status         ProjectStatus      @default(PLANNING)
  ownerId        String
  owner          User               @relation("ProjectOwner", fields: [ownerId], references: [id])
  staffId        String?
  staff          User?              @relation("ProjectStaff", fields: [staffId], references: [id], onDelete: SetNull)
  quoteRequestId String?            @unique
  quoteRequest   QuoteRequest?      @relation(fields: [quoteRequestId], references: [id], onDelete: SetNull)
  description    String?            @db.Text
  startDate      DateTime?
  dueDate        DateTime?
  progress       Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  milestones     ProjectMilestone[]
  files          ProjectFile[]
  comments       ProjectComment[]
  appointments   Appointment[]

  @@index([ownerId, status])
  @@index([staffId])
}

model ProjectMilestone {
  id            String          @id @default(cuid())
  projectId     String
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  titleVi       String
  titleDe       String
  descriptionVi String?         @db.Text
  descriptionDe String?         @db.Text
  status        MilestoneStatus @default(PENDING)
  dueDate       DateTime?
  sortOrder     Int             @default(0)
  completedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model ProjectFile {
  id        String     @id @default(cuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mediaId   String
  media     MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  label     String?
  createdAt DateTime   @default(now())
}

model ProjectComment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String   @db.Text
  isFeedback Boolean @default(false)
  rating    Int?
  createdAt DateTime @default(now())
}

model Appointment {
  id         String            @id @default(cuid())
  userId     String
  user       User              @relation("AppointmentUser", fields: [userId], references: [id], onDelete: Cascade)
  hostId     String?
  host       User?             @relation("AppointmentHost", fields: [hostId], references: [id], onDelete: SetNull)
  projectId  String?
  project    Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title      String
  notes      String?           @db.Text
  startsAt   DateTime
  endsAt     DateTime
  status     AppointmentStatus @default(PENDING)
  location   String?
  meetingUrl String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([userId, startsAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(SYSTEM)
  titleVi   String
  titleDe   String
  bodyVi    String           @db.Text
  bodyDe    String           @db.Text
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

// ─── AI ──────────────────────────────────────────────────

model AIConversation {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId String
  locale    Locale      @default(vi)
  title     String?
  purpose   String      @default("assistant") // assistant | brief | recommend | admin
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AIMessage[]

  @@index([sessionId])
  @@index([userId, createdAt])
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // user | assistant | system
  content        String         @db.Text
  structured     Json?
  approved       Boolean? // admin must approve AI content before publish
  createdAt      DateTime       @default(now())
}

// ─── Media / GDPR / System ───────────────────────────────

model MediaAsset {
  id          String          @id @default(cuid())
  userId      String?
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  kind        MediaKind       @default(OTHER)
  visibility  MediaVisibility @default(PRIVATE)
  filename    String
  storageKey  String          @unique
  mimeType    String
  extension   String
  sizeBytes   Int
  altText     String?
  url         String
  createdAt   DateTime        @default(now())
  quoteFiles  QuoteRequestFile[]
  projectFiles ProjectFile[]
}

model ConsentLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId String?
  type      String // cookies | privacy | terms | ai_processing | marketing
  granted   Boolean
  version   String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, type, createdAt])
}

model AuditLog {
  id             String        @id @default(cuid())
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  action         String
  entity         String?
  entityId       String?
  meta           Json?
  ip             String?
  quoteRequestId String?
  quoteRequest   QuoteRequest? @relation(fields: [quoteRequestId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}
